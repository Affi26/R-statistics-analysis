# --- Ladda paket ---
library(nleqslv)
# --- Konstanter vid 37°C ---
K_w <- 4.4e-14       # (Eq/L)^2
K_a <- 3e-7          # Svaga syror (Eq/L)
K_c <- 2.46e-11      # CO2-hydrering (Eq/L^2 / mmHg)
K_3 <- 6e-11         # Karbonat jämvikt (Eq/L)
# --- Oberoende variabler ---
pCO2 <- 40           # mmHg
A_tot <- 0.019       # Totala svaga syror (Eq/L)
# --- Skalningsfaktor för H (för att numeriskt stabilisera polynomet) ---
scale_factor <- 1e8
# --- Quartic-funktion: returnerar koefficienter för polyroot ---
stewart_coeffs_scaled <- function(SID, pCO2, A_tot) {
# Skala H med scale_factor: H = H_real * scale_factor
a4 <- 1
a3 <- (SID + K_a) * scale_factor
a2 <- (K_a * (SID - A_tot) - K_w - K_c * pCO2) * scale_factor^2
a1 <- -(K_a * (K_w + K_c * pCO2) - K_3 * K_c * pCO2) * scale_factor^3
a0 <- -K_a * K_3 * K_c * pCO2 * scale_factor^4
return(c(a4, a3, a2, a1, a0))
}
# --- Funktion för att lösa [H3O+] och beräkna pH ---
solve_pH <- function(SID_val, pCO2_val, A_tot_val) {
coeffs <- stewart_coeffs_scaled(SID_val, pCO2_val, A_tot_val)
roots <- polyroot(coeffs)
# Filtrera positiva reella rötter
H_scaled <- Re(roots[which(Im(roots) == 0 & Re(roots) > 0)])
if(length(H_scaled) == 0) {
warning("Ingen positiv reell rot hittad!")
return(list(H3O = NA, pH = NA, OH = NA))
}
# Skala tillbaka H till verkliga enheter
H_val <- H_scaled / scale_factor
pH <- -log10(H_val)
OH <- K_w / H_val
return(list(H3O = H_val, pH = pH, OH = OH))
}
# --- Exempel: variera SID ---
SID_vals <- seq(0.035, 0.045, length.out = 50)  # realistiskt blodplasma
pH_vals <- numeric(length(SID_vals))
for (i in seq_along(SID_vals)) {
result <- solve_pH(SID_vals[i], pCO2, A_tot)
pH_vals[i] <- result$pH
}
# --- Rita pH som funktion av SID ---
plot(SID_vals*1000, pH_vals, type='l', col='blue', lwd=2,
xlab='SID (mEq/L)', ylab='pH',
main='Stewart-modell: pH vs SID vid 37°C')
grid()
pH_vals
# Function to solve quartic equations
solve_quartic <- function(a, b, c, d, e) {
# Input validation
if (!is.numeric(c(a, b, c, d, e))) {
stop("All coefficients must be numeric.")
}
if (a == 0) {
stop("Coefficient 'a' cannot be zero for a quartic equation.")
}
# Coefficients in descending order of powers
coeffs <- c(a, b, c, d, e)
# Solve using polyroot (returns complex roots if needed)
roots <- polyroot(coeffs)
return(roots)
}
# Example usage:
# Equation: 2x^4 - 3x^3 + x^2 - 5x + 6 = 0
a <- 2
b <- -3
c <- 1
d <- -5
e <- 6
roots <- solve_quartic(a, b, c, d, e)
# Display results
cat("Roots of the quartic equation:\n")
print(roots)
