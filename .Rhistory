# --- Ladda paket ---
library(nleqslv)
# --- Konstanter vid 37°C ---
K_w <- 4.4e-14       # (Eq/L)^2
K_a <- 3e-7          # Svaga syror (Eq/L)
K_c <- 2.46e-11      # CO2-hydrering (Eq/L^2 / mmHg)
K_3 <- 6e-11         # Karbonat jämvikt (Eq/L)
# --- Oberoende variabler ---
pCO2 <- 40           # mmHg
A_tot <- 0.019       # Totala svaga syror (Eq/L)
# --- Quartic-funktion för Stewart-modellen ---
stewart_quartic <- function(H, SID, pCO2, A_tot) {
H2 <- H^2
H3 <- H^3
H4 <- H^4
term1 <- H4
term2 <- (SID + K_a) * H3
term3 <- (K_a * (SID - A_tot) - K_w - K_c * pCO2) * H2
term4 <- -(K_a * (K_w + K_c * pCO2) - K_3 * K_c * pCO2) * H
term5 <- -K_a * K_3 * K_c * pCO2
return(term1 + term2 + term3 + term4 + term5)
}
# --- Funktion för att lösa H3O+ och beräkna pH ---
solve_pH <- function(SID_val, pCO2_val, A_tot_val) {
sol <- nleqslv(
x = 4e-8,
fn = function(H) stewart_quartic(H, SID_val, pCO2_val, A_tot_val),
method = "Newton"
)
H_val <- sol$x
if(H_val <= 0) {  # Säkerhet: fysiologiskt H3O+ måste vara >0
warning("Lösning H3O+ <= 0. Kontrollera parametrar!")
H_val <- NA
}
pH <- -log10(H_val)
OH <- K_w / H_val
return(list(H3O = H_val, pH = pH, OH = OH))
}
# --- Exempel: variera SID ---
SID_vals <- seq(0.03, 0.06, length.out = 50)  # 30–60 mEq/L → 0.03–0.06 Eq/L
pH_vals <- numeric(length(SID_vals))
for (i in seq_along(SID_vals)) {
result <- solve_pH(SID_vals[i], pCO2, A_tot)
pH_vals[i] <- result$pH
}
# --- Rita pH som funktion av SID ---
plot(SID_vals*1000, pH_vals, type='l', col='blue', lwd=2,
xlab='SID (mEq/L)', ylab='pH',
main='Stewart-modell: pH vs SID vid 37°C')
grid()
# --- Oberoende variabler ---
pCO2 <- 40           # mmHg
A_tot <- 0.019       # Totala svaga syror (Eq/L)
# --- Quartic-funktion: returnerar koefficienterna för polyroot() ---
stewart_coeffs <- function(SID, pCO2, A_tot) {
a4 <- 1
a3 <- SID + K_a
a2 <- K_a * (SID - A_tot) - K_w - K_c * pCO2
a1 <- -(K_a * (K_w + K_c * pCO2) - K_3 * K_c * pCO2)
a0 <- -K_a * K_3 * K_c * pCO2
return(c(a4, a3, a2, a1, a0))
}
# --- Funktion för att lösa [H3O+] och beräkna pH med polyroot ---
solve_pH <- function(SID_val, pCO2_val, A_tot_val) {
coeffs <- stewart_coeffs(SID_val, pCO2_val, A_tot_val)
roots <- polyroot(coeffs)  # löser quartic
# Välj positiva reella rötter
H_val <- Re(roots[which(Im(roots) == 0 & Re(roots) > 0)])
if(length(H_val) == 0) {
warning("Ingen positiv reell rot hittad!")
return(list(H3O = NA, pH = NA, OH = NA))
}
pH <- -log10(H_val)
OH <- K_w / H_val
return(list(H3O = H_val, pH = pH, OH = OH))
}
# --- Exempel: variera SID ---
SID_vals <- seq(0.035, 0.045, length.out = 50)  # realistiskt blodplasma
pH_vals <- numeric(length(SID_vals))
for (i in seq_along(SID_vals)) {
result <- solve_pH(SID_vals[i], pCO2, A_tot)
pH_vals[i] <- result$pH
}
# --- Rita pH som funktion av SID ---
plot(SID_vals*1000, pH_vals, type='l', col='blue', lwd=2,
xlab='SID (mEq/L)', ylab='pH',
main='Stewart-modell: pH vs SID vid 37°C')
grid()
