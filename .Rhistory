) +
scale_color_manual(values = c("Mean 0" = "blue", "Mean 3" = "red")) +
scale_fill_manual(values = c("Mean 0" = "blue", "Mean 3" = "red")) +
scale_x_continuous(
breaks = seq(-4, 8, by = 2)
) +
labs(
title = "Two Normal Distributions with Shaded Areas",
x = "x",
y = NULL,
color = "Distribution"
) +
theme_minimal()
library(ggplot2)
x <- seq(-4, 8, length.out = 1000)
# Create combined data frame with two distributions
df <- data.frame(
x = rep(x, 2),
density = c(
dnorm(x, mean = 0, sd = 1),
dnorm(x, mean = 4, sd = 1)
),
distribution = factor(rep(c("Mean 0", "Mean 4"), each = length(x)))
)
ggplot(df, aes(x = x, y = density, color = distribution, fill = distribution)) +
# Lines for both distributions
geom_line(linewidth = 1.2) +
# Shaded area for first distribution (mean=0)
geom_ribbon(
data = subset(df, distribution == "Mean 0" & x >= -1.96 & x <= 1.96),
aes(x = x, ymin = 0, ymax = density),
alpha = 0.1,
inherit.aes = FALSE,
fill = "blue"
) +
# Shaded area for second distribution (mean=4)
geom_ribbon(
data = subset(df, distribution == "Mean 3" & x >= -1.96+4 & x <= 1.96+4),
aes(x = x, ymin = 0, ymax = density),
alpha = 0.1,
inherit.aes = FALSE,
fill = "red"
) +
scale_color_manual(values = c("Mean 0" = "blue", "Mean 3" = "red")) +
scale_fill_manual(values = c("Mean 0" = "blue", "Mean 3" = "red")) +
scale_x_continuous(
breaks = seq(-4, 8, by = 2)
) +
labs(
title = "Two Normal Distributions with Shaded Areas",
x = "x",
y = NULL,
color = "Distribution"
) +
theme_minimal()
library(ggplot2)
x <- seq(-4, 8, length.out = 1000)
# Create combined data frame with two distributions
df <- data.frame(
x = rep(x, 2),
density = c(
dnorm(x, mean = 0, sd = 1),
dnorm(x, mean = 4, sd = 1)
),
distribution = factor(rep(c("Mean 0", "Mean 4"), each = length(x)))
)
